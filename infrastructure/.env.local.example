# Run Crab Run - Local Development Environment
# Copy this to .env and modify as needed

# === Application URLs ===
RCR_LOCAL_URL=http://localhost:3000

# === Database ===
POSTGRES_PASSWORD=run-crab-run-dev-password
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# === Supabase Keys ===
# For Supabase CLI local dev (set SUPABASE_URL to enable JWKS JWT verification):
#   SUPABASE_URL=http://127.0.0.1:54321
# For self-hosted K8s (HS256 with shared secret):
#   JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://127.0.0.1:54321
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Anon key (public, safe to expose)
ANON_KEY=your-supabase-anon-key

# Service role key (secret, server-side only)
SERVICE_ROLE_KEY=your-supabase-service-role-key

# === Internal Service Configuration ===
SECRET_KEY_BASE=your-secret-key-base-at-least-32-characters-long
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min